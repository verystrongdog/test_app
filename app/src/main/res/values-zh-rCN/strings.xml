    <string name="app_name">授权后防护测试探针</string>
    <string name="headline">授权后防护测试探针</string>
    <string name="subheadline">这是一个受控 Android 探针，按基线画像、运行时观测、外传监管、权限面复核和审计快照五个模块来适配毕设项目。</string>
    <string name="switch_to_chinese">切换到中文</string>
    <string name="switch_to_english">Switch to English</string>

    <string name="coverage_title">检测器模块覆盖</string>
    <string name="coverage_baseline">模块 1 - 基线画像：已具备可疑包名标签、宽权限声明、网络访问和包可见性。</string>
    <string name="coverage_runtime">模块 2 - 运行时观测：手动通知、前台服务上传链和延迟后台探测都会产生可观察行为。</string>
    <string name="coverage_outbound">模块 3 - 外传监管：直接 POST 上传、前台重试突发链和后台上传都会触发网络外发。</string>
    <string name="coverage_permission_surface">模块 4 - 权限面：已覆盖运行时权限申请、应用设置复核，以及联系人、媒体、位置、电话状态、麦克风和相机访问。</string>
    <string name="coverage_audit">模块 5 - 审计快照：已内置本地报告持久化、事件日志和 JSON 导出。</string>

    <string name="module_baseline_title">模块 1 - 基线画像</string>
    <string name="module_baseline_summary">刷新声明能力面并枚举已安装应用，让检测器能把这个探针识别成高风险目标。</string>
    <string name="module_runtime_title">模块 2 - 运行时观测</string>
    <string name="module_runtime_summary">触发通知、前台服务和延迟后台行为，让检测器关联前台可见与后台不可见的运行时信号。</string>
    <string name="module_outbound_title">模块 3 - 外传监管</string>
    <string name="module_outbound_summary">把探针指向 HTTP 端点，生成可重复的外发流量，用于 VPN 有界验证和外传审查。</string>
    <string name="module_permission_title">模块 4 - 权限面</string>
    <string name="module_permission_summary">申请高危权限并执行受控读取，让检测器的每个敏感面都能在真机上被触发。</string>
    <string name="module_audit_title">模块 5 - 审计快照</string>
    <string name="module_audit_summary">保存最新报告、事件历史和导出的 JSON 证据，方便论文截图和可复现验证记录。</string>

