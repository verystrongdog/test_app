    <string name="app_name">Post-Consent Test Probe</string>
    <string name="headline">Post-Consent Test Probe</string>
    <string name="subheadline">A controlled Android probe aligned with baseline profiling, runtime observation, outbound supervision, permission surface review, and audit snapshot demos.</string>
    <string name="switch_to_chinese">切换到中文</string>
    <string name="switch_to_english">Switch to English</string>

    <string name="coverage_title">Detector Module Coverage</string>
    <string name="coverage_baseline">Module 1 - Baseline profiling: suspicious package label, broad declared permissions, network access, and package visibility are all present.</string>
    <string name="coverage_runtime">Module 2 - Runtime observation: manual notification, foreground-service upload chain, and delayed background probe all emit observable behavior.</string>
    <string name="coverage_outbound">Module 3 - Outbound supervision: direct POST upload, foreground retry burst, and background upload all exercise network egress.</string>
    <string name="coverage_permission_surface">Module 4 - Permission surface: runtime permission requests, app-settings review, contacts, media, location, phone-state, microphone, and camera access are available.</string>
    <string name="coverage_audit">Module 5 - Audit snapshot: local report persistence, event logging, and JSON export are built in.</string>

    <string name="module_baseline_title">Module 1 - Baseline Profiling</string>
    <string name="module_baseline_summary">Refresh the declared capability surface and enumerate installed packages so the detector can score this probe as a high-risk target.</string>
    <string name="module_runtime_title">Module 2 - Runtime Observation</string>
    <string name="module_runtime_summary">Trigger notification, foreground-service, and delayed background behavior so the detector can correlate visible and non-visible runtime signals.</string>
    <string name="module_outbound_title">Module 3 - Outbound Supervision</string>
    <string name="module_outbound_summary">Point the probe at an HTTP endpoint and generate reproducible outbound traffic for VPN-bound validation and exfiltration review.</string>
    <string name="module_permission_title">Module 4 - Permission Surface</string>
    <string name="module_permission_summary">Request the risky runtime set and perform controlled reads so each sensitive surface in the detector can be exercised on-device.</string>
    <string name="module_audit_title">Module 5 - Audit Snapshot</string>
    <string name="module_audit_summary">Persist the latest report, event history, and exported JSON evidence for thesis screenshots and replayable validation records.</string>

